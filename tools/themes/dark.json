    "async":    { "stroke": "#fbbf24", "style": "dashed", "width": 1.5 },
    "error":    { "stroke": "#f87171", "style": "dashed", "width": 1.5 },
    "auth":     { "stroke": "#fb923c", "style": "solid", "width": 1.5 },
    "data":     { "stroke": "#a78bfa", "style": "solid", "width": 1.5 },
