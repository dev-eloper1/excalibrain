    "gateway":      { "fill": "#064e3b", "stroke": "#34d399", "textColor": "#a7f3d0" },
    "service":      { "fill": "#064e3b", "stroke": "#34d399", "textColor": "#a7f3d0" },
    "async":        { "fill": "#422006", "stroke": "#fbbf24", "textColor": "#fef3c7" },
    "data":         { "fill": "#2e1065", "stroke": "#a78bfa", "textColor": "#ddd6fe" },
    "observability": { "fill": "#4c0519", "stroke": "#f43f5e", "textColor": "#fecdd3" },
    "ai":           { "fill": "#2e1065", "stroke": "#a78bfa", "textColor": "#ddd6fe" },
    "external":     { "fill": "#451a03", "stroke": "#fb923c", "textColor": "#fed7aa" },
