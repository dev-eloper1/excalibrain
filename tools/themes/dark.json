    "success":      { "fill": "#064e3b", "stroke": "#34d399", "textColor": "#a7f3d0" },
    "error":        { "fill": "#450a0a", "stroke": "#f87171", "textColor": "#fecaca" },
    "legacy":       { "fill": "#1e293b", "stroke": "#64748b", "textColor": "#94a3b8" },
