{
  "name": "dark",
  "description": "Dark background with vibrant node colors and light text",
  "canvas": {
    "background": "#0f172a"
  },
  "style": {
    "roughness": 0,
    "fontFamily": 1,
    "fontSize": 16,
    "nodeFill": "solid",
    "nodeWidth": 1.5,
    "arrowWidth": 1.5,
    "zoneFill": "solid",
    "zoneOpacity": 15,
    "zoneLabelFont": 2,
    "zoneLabelSize": 13,
    "edgeLabelSize": 13,
    "titleSize": 22,
    "titleColor": "#e2e8f0",
