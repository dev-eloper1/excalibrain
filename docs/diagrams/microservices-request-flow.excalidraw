      "boundElements": null,
      "link": null,
      "locked": false,
      "text": "SAGA PATTERN: each step has\na compensating action. Failures\nrun compensation in reverse\norder — refund, then release.",
      "originalText": "SAGA PATTERN: each step has\na compensating action. Failures\nrun compensation in reverse\norder — refund, then release.",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#6b7280",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
