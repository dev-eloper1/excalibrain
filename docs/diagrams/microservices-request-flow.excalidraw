    },
    {
      "type": "text",
      "id": "ordrzmanno_ttl",
      "x": 743.5,
      "y": 4666,
      "width": 220,
      "height": 73,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 10116,
      "version": 1,
      "versionNonce": 10117,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "text": "5-min TTL on inventory hold\nprevents phantom stock. If\npayment is slow, hold expires\nand order fails gracefully.",
      "originalText": "5-min TTL on inventory hold\nprevents phantom stock. If\npayment is slow, hold expires\nand order fails gracefully.",
