    {
      "type": "text",
      "id": "comp_n1",
      "x": 1700,
      "y": 440,
      "width": 327.59999999999997,
      "height": 77.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95000,
      "version": 1,
      "versionNonce": 95001,
      "isDeleted": false,
      "groupIds": [
        "59eec6ebb8171b82673f"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "↑ The territory: 6 branches of the idea.\nKey finding: .excalidrawlib files are just\npackaged Excalidraw elements — we already\nknow how to produce these.",
      "originalText": "↑ The territory: 6 branches of the idea.\nKey finding: .excalidrawlib files are just\npackaged Excalidraw elements — we already\nknow how to produce these.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n2",
      "x": 500,
      "y": 580,
      "width": 288.59999999999997,
      "height": 77.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95002,
      "version": 1,
      "versionNonce": 95003,
      "isDeleted": false,
      "groupIds": [
        "3e641f655a45d49fa5f8"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "The shadcn insight: once a component\nis in YOUR library, it doesn't matter\nif you made it or borrowed it.\nYou own it. You modify it.",
      "originalText": "The shadcn insight: once a component\nis in YOUR library, it doesn't matter\nif you made it or borrowed it.\nYou own it. You modify it.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n3",
      "x": 1282,
      "y": 1050,
      "width": 265.2,
      "height": 77.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95004,
      "version": 1,
      "versionNonce": 95005,
      "isDeleted": false,
      "groupIds": [
        "92241022d6d06965e278"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "The agent should think BY drawing,\nnot stop thinking TO draw.\nSkills solved this for text.\nLibraries solve this for visuals.",
      "originalText": "The agent should think BY drawing,\nnot stop thinking TO draw.\nSkills solved this for text.\nLibraries solve this for visuals.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n4",
      "x": 50,
      "y": 1780,
      "width": 327.59999999999997,
      "height": 94.5,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95006,
      "version": 1,
      "versionNonce": 95007,
      "isDeleted": false,
      "groupIds": [
        "6cac59eeee8e7ed1cac3"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "Phase shift: from \"why\" to \"how\".\nThree authoring modes match three\nmoments: know what you want (declarative),\nalready made it (extractive),\nfiguring it out together (interactive).",
      "originalText": "Phase shift: from \"why\" to \"how\".\nThree authoring modes match three\nmoments: know what you want (declarative),\nalready made it (extractive),\nfiguring it out together (interactive).",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n5",
      "x": 1086,
      "y": 2400,
      "width": 280.8,
      "height": 94.5,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95008,
      "version": 1,
      "versionNonce": 95009,
      "isDeleted": false,
      "groupIds": [
        "36e8c8fc41da8171ae7f"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "Intelligence builds in layers:\nv1: placement hints (zone affinity)\nv2: parameterized (React-like props)\nv3: composition templates (patterns)\nEach layer enables the next.",
      "originalText": "Intelligence builds in layers:\nv1: placement hints (zone affinity)\nv2: parameterized (React-like props)\nv3: composition templates (patterns)\nEach layer enables the next.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n6",
      "x": 700,
      "y": 2838,
      "width": 319.8,
      "height": 77.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95010,
      "version": 1,
      "versionNonce": 95011,
      "isDeleted": false,
      "groupIds": [
        "8bf4814acfb653b1017a"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "Core decision: library-resolve.js is the\nstable center. dagre, primitives, mermaid\nall consult it. v2 and v3 extend it,\nnever replace it.",
      "originalText": "Core decision: library-resolve.js is the\nstable center. dagre, primitives, mermaid\nall consult it. v2 and v3 extend it,\nnever replace it.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n7",
      "x": 2750,
      "y": 480,
      "width": 210.6,
      "height": 72.4,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95012,
      "version": 1,
      "versionNonce": 95013,
      "isDeleted": false,
      "groupIds": [
        "760af927acdc7e63cc7b"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "meta: this canvas is itself\nthe proof of concept —\nwe brainstormed through\ndiagrams, not about them.",
      "originalText": "meta: this canvas is itself\nthe proof of concept —\nwe brainstormed through\ndiagrams, not about them.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n8",
      "x": 2750,
      "y": 1300,
      "width": 234,
      "height": 103.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95014,
      "version": 1,
      "versionNonce": 95015,
      "isDeleted": false,
      "groupIds": [
        "21e2732c5db0c81cd60b"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "\"a picture worth 1000 words\"\nnot just functional diagrams —\nvisual arguments with the\nquality of hand-crafted\nillustrations. The library\nsystem is how we get there.",
      "originalText": "\"a picture worth 1000 words\"\nnot just functional diagrams —\nvisual arguments with the\nquality of hand-crafted\nillustrations. The library\nsystem is how we get there.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n9",
      "x": 2750,
      "y": 2600,
      "width": 226.2,
      "height": 103.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95016,
      "version": 1,
      "versionNonce": 95017,
      "isDeleted": false,
      "groupIds": [
        "66bb8748b6967735dd0c"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "future: when Hermes gets a\ncustom frontend, the registry\nbecomes a UI. Agent and human\nshare the same visual canvas.\nThe Knuth process happens\nON the canvas, not about it.",
      "originalText": "future: when Hermes gets a\ncustom frontend, the registry\nbecomes a UI. Agent and human\nshare the same visual canvas.\nThe Knuth process happens\nON the canvas, not about it.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
    {
      "type": "text",
      "id": "comp_n10",
      "x": 30,
      "y": 1918.5,
      "width": 257.4,
      "height": 103.60000000000001,
      "angle": 0,
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "seed": 95018,
      "version": 1,
      "versionNonce": 95019,
      "isDeleted": false,
      "groupIds": [
        "64d1bf210090d8cb157e"
      ],
      "boundElements": null,
      "link": null,
      "locked": false,
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "fontSize": 13,
      "fontFamily": 3,
      "strokeColor": "#1e293b",
      "textAlign": "left",
      "verticalAlign": "top",
      "text": "quality ceiling: raw rectangles +\ntext can't carry design intent.\nLibrary components carry polish\nbuilt-in — the agent just says\n\"use section-card\" and gets\nvisual quality for free.",
      "originalText": "quality ceiling: raw rectangles +\ntext can't carry design intent.\nLibrary components carry polish\nbuilt-in — the agent just says\n\"use section-card\" and gets\nvisual quality for free.",
      "containerId": null,
      "autoResize": true,
      "lineHeight": 1.3,
      "frameId": null
    },
